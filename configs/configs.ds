>>> FILE waybar/config.jsonc
{
    "layer": "top",
    "exclusive": true,
    "passthrough": false,
    "position": "top",
    "spacing": 8,
    "fixed-center": true,
    "ipc": true,
    "margin-top": 3,
    "margin-left": 8,
    "margin-right": 8,
    "modules-left": [
        "group/debian",
        "clock",
        "dwl/tags"
    ],
    "modules-center": [
        "custom/dnd"
    ],
    "modules-right": [
        "battery",
        "group/system",
        "group/connections"
    ],
    "custom/debian": {
        "format": "<span size='large'></span>",
        "tooltip": false
    },
    "dwl/tags": {
        "format": "{name}",
        "on-click": "dwl -c dwltags {id}",
        "tooltip": false
    },
    "custom/dnd": {
        "format": "{icon}",
        "format-icons": {
            "enabled": "<span size='large'>󰂛</span>",
            "disabled": "<span size='large'>󰂚</span>"
        },
        "exec": "makoctl mode | grep -q enabled && echo enabled || echo disabled",
        "on-click": "makoctl mode -t dnd",
        "interval": 1,
        "tooltip": false
    },
    "custom/whitespace": {
        "format": " "
    },
    "group/debian": {
        "orientation": "horizontal",
        "modules": [
            "custom/debian",
            "custom/whitespace"
        ]
    },
    "clock": {
        "format": "<span size='large'>󰃭</span>  {:%b %d  %H:%M}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#{{cal_month}}'><b>{}</b></span>",
                "days": "<span color='#{{cal_days}}'><b>{}</b></span>",
                "weeks": "<span color='#{{cal_weeks}}'><b>W{}</b></span>",
                "weekdays": "<span color='#{{cal_weekdays}}'><b>{}</b></span>",
                "today": "<span color='#{{cal_today}}'><b><u>{}</u></b></span>"
            }
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "<span size='large'>{icon}</span> {capacity}%",
        "format-charging": "<span size='large'>󰂄</span> {capacity}%",
        "format-plugged": "<span size='large'>󰚥</span> {capacity}%",
        "format-icons": [
            "<span size='large'>󰂎</span>",
            "<span size='large'>󰁺</span>",
            "<span size='large'>󰁻</span>",
            "<span size='large'>󰁼</span>",
            "<span size='large'>󰁽</span>",
            "<span size='large'>󰁾</span>",
            "<span size='large'>󰁿</span>",
            "<span size='large'>󰂀</span>",
            "<span size='large'>󰂁</span>",
            "<span size='large'>󰂂</span>",
            "<span size='large'>󰁹</span>"
        ]
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "group/system": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "temperature"
        ]
    },
    "group/connections": {
        "orientation": "horizontal",
        "modules": [
            "network",
            "pulseaudio",
            "pulseaudio#microphone"
        ]
    },
    "cpu": {
        "format": " {usage}%",
        "tooltip": true,
        "interval": 1,
        "min-size": 50
    },
    "memory": {
        "format": " <span size='small'> </span><span size='large'>󰆼</span> {}%",
        "tooltip-format": "Used: {used:0.1f}GB\nTotal: {total:0.1f}GB"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input ",
        "critical-threshold": 80,
        "format-critical": "  <span></span> {temperatureC}°C",
        "format": "  <span></span> {temperatureC}°C",
        "format-icons": [
            "<span size='large'></span>"
        ]
    },
    "network": {
        "format-wifi": " <span size='large'>{icon}</span><span size='small'>  </span>",
        "format-ethernet": " <span size='large'>󰈁</span> ",
        "format-linked": " <span size='large'>󰈁</span>  ",
        "format-disconnected": " <span size='large'>󰤮</span>  ",
        "tooltip-format": " <span size='large'>󰈁</span> {ifname} via {gwaddr}",
        "format-icons": [
            "󰤯",
            "󰤟",
            "󰤢",
            "󰤥",
            "󰤨"
        ],
        "on-click": "alacritty -e nmtui"
    },
    "bluetooth": {
        "format": " <span size='large'>󰂯</span>  ",
        "format-connected": " <span size='large'>󰂱</span>  ",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager"
    },
    "pulseaudio": {
        "format": " {icon}   ",
        "format-bluetooth": " <span size='large'>󰂰</span>   ",
        "format-bluetooth-muted": "<span size='large'>󰂲</span>   ",
        "format-muted": " <span size='large'>󰖁</span>   ",
        "format-icons": {
            "headphone": "<span size='large'>󰋋</span>",
            "hands-free": "<span size='large'>󰋎</span>",
            "headset": "<span size='large'>󰋎</span>",
            "phone": "<span size='large'>󰏲</span>",
            "portable": "<span size='large'>󰄝</span>",
            "car": "<span size='large'>󰄋</span>",
            "default": [
                "<span size='large'>󰕿</span>",
                "<span size='large'>󰖀</span>",
                "<span size='large'>󰕾</span>"
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -i audio-volume-muted-symbolic \"Volume toggled\"",
        "on-click-right": "pavucontrol"
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "<span size='large'>󰍬</span> ",
        "format-source-muted": "<span size='large'>󰍭</span> ",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle && notify-send -h string:x-canonical-private-synchronous:sys-notify -u low -i microphone-sensitivity-muted-symbolic \"Microphone toggled\"",
        "on-click-right": "pavucontrol"
    }
}
<<< END

>>> FILE waybar/style.css
* {
    font-family: "BigBlueTermPlusNerdFont", "BigBlueTerminal NFP", "FiraCode Nerd Font", monospace;
    font-weight: normal;
    font-size: 11.5px;
    min-height: 0;
    border: none;
    border-radius: 0;
    margin: 0;
    padding: 0;
}

window#waybar {
    background: transparent;
    color: #{{text}};
}

.modules-left > widget > *:not(#workspaces),
.modules-center > widget > *:not(#workspaces),
.modules-right > widget > *:not(#workspaces) {
    margin: 0 2px;
    padding: 4px 12px;
    background-color: rgba({{bg_rgb}}, 0.95);
    border: 2px solid rgba({{accent_rgb}}, 0.75);
    border-radius: 10px;
    color: #{{text}};
}

#group {
    background-color: #{{bg}};
    border: 2px solid rgba({{accent_rgb}}, 0.4);
    border-radius: 10px;
    margin: 0 2px;
    padding: 2px 4px;
}

group > widget > * {
    margin: 0 2px;
    padding: 4px 6px;
    border: none;
    background: none;
    color: #{{text}};
}

group > widget:first-child > * {
    margin-left: 0;
}

group > widget:last-child > * {
    margin-right: 0;
}

.modules-left {
    margin-left: 2px;
}

.modules-right {
    margin-right: 2px;
}

#workspaces {
    margin: 0 2px;
    padding: 0;
}

#workspaces button {
    padding: 0 6px;
    font-size: 13px;
    font-weight: bold;
    background-color: #{{bg}};
    border: 2px solid rgba({{accent_rgb}}, 0.75);
    border-radius: 10px;
    margin: 0 2px;
    color: #{{muted}};
    transition: all 0.2s ease;
}

#workspaces button:hover {
    background-color: #{{bg_soft}};
    color: #{{text}};
}

#workspaces button.active {
    background-color: #{{surface}};
    color: #{{text}};
}

#custom-debian {
    font-size: 15px;
    padding: 4px 8px 4px 10px;
}

#custom-whitespace {
    font-size: 0;
    padding: 0;
    border: none;
    background: none;
}

#custom-niri-windows {
    font-family: 'Uiua386';
    font-size: 16px;
}

#custom-dnd,
#tray {
    padding: 4px 8px;
}

#clock {
    padding: 4px 14px;
}

#battery {
    padding: 4px 12px;
}

#pulseaudio {
    font-size: 13px;
}

#cpu {
    min-width: 38px;
}

#network {
    padding-right: 6px;
}

#battery.warning {
    color: #{{yellow_hi}};
}

#battery.critical {
    color: #{{red_hi}};
}

#battery progressbar {
    background-color: #{{surface}};
    border-radius: 2px;
}

#battery progressbar > progress {
    min-width: 50px;
    background-color: #{{green_hi}};
    border-radius: 2px;
}

#tags {
    padding: 0 2px;
}

#tags button {
    background: none;
    border: none;
    border-radius: 4px;
    padding: 4px 5px;
    color: #{{tag_idle}};
    font-weight: bold;
    transition: color 0.15s;
    min-width: 0;
}

#tags button.occupied {
    color: #{{tag_occupied}};
}

#tags button.focused {
    color: #{{tag_focused}};
}

#tags button.urgent {
    color: #{{tag_urgent}};
}
<<< END

>>> FILE .zshrc
export DS_THEME_BG="#{{bg}}"
export DS_THEME_TEXT="#{{text}}"
export DS_THEME_ACCENT="#{{accent}}"
export DS_THEME_PANEL="#{{panel}}"
<<< END
