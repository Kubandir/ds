>>> FILE alacritty/alacritty.toml
[window]
opacity = 0.85
blur = true

[window.padding]
x = 14
y = 10

[font.normal]
family = "BigBlueTermPlus Nerd Font"

[cursor.style]
shape = "Beam"

[colors.primary]
background = "#{{bg}}"
foreground = "#{{text}}"
dim_foreground = "#{{text_dim}}"
bright_foreground = "#{{text_hi}}"

[colors.cursor]
text   = "#{{bg}}"
cursor = "#{{accent}}"

[colors.vi_mode_cursor]
text   = "#{{bg}}"
cursor = "#{{accent_hi}}"

[colors.search.matches]
foreground = "#{{bg}}"
background = "#{{accent}}"

[colors.search.focused_match]
foreground = "#{{bg}}"
background = "#{{accent_hi}}"

[colors.hints.start]
foreground = "#{{bg}}"
background = "#{{accent}}"

[colors.hints.end]
foreground = "#{{bg}}"
background = "#{{panel}}"

[colors.selection]
text       = "#{{text}}"
background = "#{{surface}}"

[colors.normal]
black   = "#{{bg_soft}}"
red     = "#{{red}}"
green   = "#{{green}}"
yellow  = "#{{yellow}}"
blue    = "#{{blue}}"
magenta = "#{{magenta}}"
cyan    = "#{{panel}}"
white   = "#{{muted}}"

[colors.bright]
black   = "#{{dark2}}"
red     = "#{{red_hi}}"
green   = "#{{green_hi}}"
yellow  = "#{{yellow_hi}}"
blue    = "#{{accent}}"
magenta = "#{{magenta_hi}}"
cyan    = "#{{accent_hi}}"
white   = "#{{text}}"

[colors.dim]
black   = "#{{bg}}"
red     = "#{{dark_red}}"
green   = "#{{dark_green}}"
yellow  = "#{{dark_yellow}}"
blue    = "#{{dark_blue}}"
magenta = "#{{dark_magenta}}"
cyan    = "#{{dark_cyan}}"
white   = "#{{dark_text}}"
<<< END

>>> FILE fuzzel/fuzzel.ini
