>>> FILE mango/autostart.sh
#!/bin/sh
_restart() {
    pkill -x "$1" 2>/dev/null
    sleep 0.1
    shift
    "$@" &
}

_restart swaybg swaybg -i "$HOME/Media/Wallpaper.png" --mode fill
_restart mako mako
_restart waybar waybar

pkill -x xwayland-satellite 2>/dev/null
sleep 0.1
xwayland-satellite :1 &
export DISPLAY=:1

export XCURSOR_THEME=Bibata-Original-Ice
export XCURSOR_SIZE=24
gsettings set org.gnome.desktop.interface cursor-theme 'Bibata-Original-Ice'
gsettings set org.gnome.desktop.interface cursor-size 24
xsetroot -cursor_name left_ptr &
<<< END

